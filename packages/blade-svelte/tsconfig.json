{
  "extends": "../../tsconfig.json",
  "include": ["src"],
  "exclude": ["node_modules/**/*", "**/*.test.ts", "**/*.test.svelte"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~components/*": ["src/components/*"],
      "~src/*": ["src/*"]
    },
    "moduleSuffixes": [""],
    "types": ["svelte"],
    "verbatimModuleSyntax": true,
    "moduleResolution": "bundler"
  }
}

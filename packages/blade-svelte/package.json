{
  "name": "@razorpay/blade-svelte",
  "version": "0.9.0",
  "description": "Blade Design System for Svelte",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.12.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "ssh://git@github.com/razorpay/blade.git"
  },
  "keywords": [
    "design system",
    "svelte",
    "razorpay",
    "blade"
  ],
  "exports": {
    "./components": {
      "types": "./dist/types/components/index.d.ts",
      "svelte": "./dist/lib/components/index.js",
      "default": "./dist/lib/components/index.js"
    },
    "./utils": {
      "types": "./dist/types/utils/index.d.ts",
      "default": "./dist/lib/utils/index.js"
    }
  },
  "svelte": "./dist/lib/components/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "yarn build",
    "build": "npm-run-all build:clean build:generate-types build:lib",
    "build:clean": "rm -rf dist",
    "build:generate-types": "tsc -p ./tsconfig-generate-types.json",
    "build:lib": "rollup -c",
    "svelte-check": "svelte-check --tsconfig ./tsconfig.json",
    "svelte-check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "dev": "npm-run-all --parallel dev:blade-core storybook",
    "dev:blade-core": "cd ../blade-core && yarn build:watch",
    "prestorybook": "cd ../blade-core && yarn build",
    "start:web": "yarn dev",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build -o storybook-static",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:browserstack": "playwright test -c tests/browserstack/playwright.config.cts",
    "test:browserstack:local": "CHROMATIC_URL=https://blade.razorpay.com playwright test -c tests/browserstack/playwright.config.cts",
    "test:browserstack:mobile": "browserstack-node-sdk playwright test --config tests/browserstack/playwright.mobile.config.cts",
    "test:browserstack:mobile:local": "CHROMATIC_URL=https://blade.razorpay.com browserstack-node-sdk playwright test --config tests/browserstack/playwright.mobile.config.cts",
    "pregenerate-bundle-size-info": "yarn run-s build:clean build:generate-types build:lib",
    "generate-bundle-size-info": "node ./scripts/generateBundleSizeInfo.js"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.0",
    "@razorpay/blade-core": ">=0.8.0",
    "@razorpay/i18nify-js": "1.12.3",
    "@use-gesture/vanilla": "10.2.24",
    "body-scroll-lock-upgrade": "1.1.0",
    "class-variance-authority": "^0.7.0"
  },
  "devDependencies": {
    "@babel/core": "7.21.8",
    "@babel/parser": "7.28.3",
    "@babel/traverse": "7.28.3",
    "@playwright/test": "^1.52.0",
    "@babel/preset-typescript": "7.16.5",
    "@testing-library/jest-dom": "^6",
    "@testing-library/svelte": "5.4.2",
    "@testing-library/user-event": "^14",
    "@vitest/coverage-v8": "3.2.6",
    "jsdom": "^25",
    "vitest": "3.2.6",
    "browserstack-node-sdk": "1.60.1",
    "danger": "11.3.1",
    "dotenv": "^16.4.5",
    "execa": "5.0.0",
    "@rollup/plugin-alias": "5.0.0",
    "@rollup/plugin-babel": "6.0.3",
    "@rollup/plugin-commonjs": "25.0.4",
    "@rollup/plugin-node-resolve": "15.2.1",
    "@size-limit/preset-big-lib": "11.2.0",
    "@storybook/addon-docs": "~10.2.0",
    "@storybook/addon-links": "~10.2.0",
    "@storybook/addon-svelte-csf": "^5.0.10",
    "@storybook/svelte-vite": "^10.1.2",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^20.0.0",
    "magic-string": "^0.30.5",
    "npm-run-all": "4.1.5",
    "prettier": "2.2.1",
    "rollup": "3.29.5",
    "rollup-plugin-peer-deps-external": "2.2.4",
    "rollup-plugin-postcss": "4.0.2",
    "rollup-plugin-svelte": "^7.2.2",
    "size-limit": "11.2.0",
    "storybook": "^10.1.2",
    "svelte": "5.35.2",
    "svelte-check": "^4.0.0",
    "svelte-preprocess": "^6.0.3",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "peerDependencies": {
    "svelte": ">=5.35.0"
  }
}

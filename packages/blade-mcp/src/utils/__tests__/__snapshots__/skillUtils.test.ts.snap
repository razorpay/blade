// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`skillUtils > skillCreationInstructions > should return consistent instructions for skill creation (snapshot) 1`] = `
"
**Instructions:**

1. Change to the working directory: \`cd "/Users/test/project"\`

2. Run the bash script below (copy and execute the commands from the script)

3. This will create the blade skill at \`.agents/skills/blade-usage-guidelines/SKILL.md\` and a symlink at \`.claude/skills/blade-usage-guidelines\`

Run the following bash script to create the blade skill:

**Bash Script:**

\`\`\`bash

  #!/bin/bash
  # Download blade-usage-guidelines SKILL.md from GitHub and save to .agents/skills/blade-usage-guidelines
  SKILL_DIR=".agents/skills/blade-usage-guidelines"
  SYMLINK_DIR=".claude/skills/blade-usage-guidelines"
  URL="https://raw.githubusercontent.com/razorpay/blade/master/packages/blade-mcp/skillTemplate/SKILL.md"
  FILE_PATH="$SKILL_DIR/SKILL.md"
  # Create directory if it doesn't exist
  mkdir -p "$SKILL_DIR"
  curl -sSL "$URL" -o "$FILE_PATH"
  # Create symlink for Claude Code support
  mkdir -p ".claude/skills"
  if [ ! -L "$SYMLINK_DIR" ] && [ ! -e "$SYMLINK_DIR" ]; then
    ln -s "../../.agents/skills/blade-usage-guidelines" "$SYMLINK_DIR"
  fi
  
\`\`\`

**Working Directory:** \`/Users/test/project\`
"
`;
